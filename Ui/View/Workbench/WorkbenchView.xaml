<UserControl x:Class="_1RM.View.Workbench.WorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="https://github.com/canton7/Stylet"
             xmlns:workbench="clr-namespace:_1RM.View.Workbench"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance workbench:WorkbenchViewModel}"
             d:DesignWidth="1200"
             d:DesignHeight="700">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="46"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource PrimaryDarkBrush}">
            <ItemsControl ItemsSource="{Binding Activities}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type workbench:WorkbenchActivityItem}">
                        <Border Height="42" Margin="0,2" Background="Transparent" ToolTip="{Binding Label}">
                            <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PrimaryMidBrush}" BorderBrush="{DynamicResource DefaultBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Margin="12,0" VerticalAlignment="Center" Text="Explorer" Style="{StaticResource TextBlockBase}"/>
                <Border Grid.Row="1" Margin="0" CornerRadius="0" BorderThickness="0" Background="{DynamicResource BackgroundBrush}">
                    <ContentControl s:View.Model="{Binding DataContext.ActiveServerViewModel, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource BackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource PrimaryMidBrush}" BorderBrush="{DynamicResource DefaultBorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Margin="12,0" VerticalAlignment="Center" Text="Editor Area" Style="{StaticResource TextBlockBase}"/>
                </Border>
                <Grid Grid.Row="1" Background="{DynamicResource BackgroundBrush}">
                    <ContentControl s:View.Model="{Binding DataContext.SettingViewModel, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ShowSetting, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                    <ContentControl s:View.Model="{Binding DataContext.EditorViewModel, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.EditorViewModel, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource PrimaryMidBrush}" BorderBrush="{DynamicResource DefaultBorderBrush}" BorderThickness="0,1,0,1">
            <TextBlock Margin="12,0" VerticalAlignment="Center" Text="Bottom Panel (reserved)" Style="{StaticResource TextBlockBase}"/>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="{DynamicResource AccentDarkBrush}">
            <DockPanel Margin="10,0">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{DynamicResource AccentTextBrush}" Text="Status"/>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{DynamicResource AccentTextBrush}" Text="1Remote Workbench"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
